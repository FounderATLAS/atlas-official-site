---
import { Icon } from 'astro-icon/components';
import {
	Container,
	Button,
	ThreeColumnTextSection,
	CtaCardSection,
} from '@components/odyssey-theme';
import Layout from '../layouts/Page.astro';
import HomeHeroSection from '../components/sections/heros/HomeHeroSection.astro';

const seo = {
	title: 'ATLAS | Asset & Technology Landscape Audit Solutions',
	description: 'ATLAS helps organizations gain full visibility into their asset and technology landscape through comprehensive audits and strategic guidance.',
};
---

<Layout {seo}>
	<HomeHeroSection />

	<ThreeColumnTextSection>
		<div slot="column-1-body">
			<h2>Asset Discovery</h2>
			<p>
				We identify and catalog every asset across your organization, 
				giving you a single source of truth for your entire 
				technology landscape.
			</p>
		</div>
		<Button slot="column-1-cta" href="/company/about">Learn More</Button>
		<div slot="column-2-body">
			<h2>Risk Assessment</h2>
			<p>
				We evaluate vulnerabilities, outdated systems, and compliance 
				gaps so you can prioritize what matters most.
			</p>
		</div>
		<Button slot="column-2-cta" href="/company/about" outlined>Learn More</Button>
		<div slot="column-3-body">
			<h2>Strategic Roadmap</h2>
			<p>
				We deliver clear recommendations and a prioritized action plan 
				to optimize your technology investments.
			</p>
		</div>
		<Button slot="column-3-cta" href="/company/about">Learn More</Button>
	</ThreeColumnTextSection>

	<Container>
		<section class="why-atlas__section">
			<h2>Why Choose ATLAS?</h2>
			<p>
				Most organizations don't have complete visibility into their technology 
				assets. Shadow IT, outdated systems, and compliance gaps create hidden 
				risks. ATLAS gives you clarity and control.
			</p>
		</section>
	</Container>

	<CtaCardSection
		background="var(--theme-surface-2)"
		color="var(--theme-on-surface-2)"
	>
		<h2>Ready to Get Started?</h2>
		<p>
			Contact us today to schedule your first asset and technology audit.
		</p>
		<Button href="/company/contact" customIcon>
			Contact Us <Fragment slot="icon">
				<Icon name="ic:baseline-chevron-right" />
			</Fragment>
		</Button>
	</CtaCardSection>
</Layout>

<style>
	.why-atlas__section {
		margin: var(--section-margin) auto;
		text-align: center;
		max-width: 800px;
	}
	.why-atlas__section h2 {
		margin-bottom: 1rem;
	}
	.why-atlas__section p {
		font-size: var(--font-size-md);
		opacity: 0.85;
	}
</style>