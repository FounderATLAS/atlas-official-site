<div class="atlas-logo">
  <img src="/atlas-v14-circle-polish-2.png" alt="ATLAS" />
  <span class="atlas-logo__text">ATLAS</span>
</div>

<style>
  .atlas-logo {
    width: fit-content;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .atlas-logo img {
    height: 44px;
    width: auto;
    object-fit: contain;
    display: block;
  }

  .atlas-logo__text {
    font-family: var(--theme-font-family-serif);
    font-size: var(--font-size-md);
    font-weight: 700;
    color: inherit;
    line-height: 1;
    transition: color 150ms ease;
  }

  .atlas-logo:hover {
    cursor: pointer;
  }

  .atlas-logo:hover .atlas-logo__text {
    color: #C9A84C;
  }
</style>