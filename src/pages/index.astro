---
import { Icon } from 'astro-icon/components';
import { Container, Button } from '@components/odyssey-theme';
import Layout from '../layouts/Page.astro';

const seo = {
	title: 'ATLAS | Asset & Technology Landscape Audit Solutions',
	description: 'ATLAS autonomously discovers every unauthorized tool, forgotten subscription, and shadow AI exposure inside your organization — in under 15 minutes, without touching a single byte of your data.',
};
---

<Layout {seo}>

  <!-- ============================================
       SECTION 1 — HERO
       ============================================ -->
  <section class="hero">
    <Container>
      <div class="hero__inner">
        <div class="hero__text">
          <p class="hero__eyebrow">Shadow AI · SaaS Waste · Security Exposure</p>
          <h1 class="hero__headline">
            Your organization is bleeding capital and leaking IP right now. You just don't know it yet.
          </h1>
          <p class="hero__sub">
            ATLAS autonomously discovers every unauthorized tool, forgotten subscription, and shadow AI exposure inside your organization — in under 15 minutes, without touching a single byte of your data.
          </p>
          <div class="hero__btns">
            <a href="/company/contact" class="btn-gold">
              Get a Free Shadow AI Risk Scan
            </a>
            <a href="#how-it-works" class="btn-outline-white">
              See How It Works
            </a>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- ============================================
       SECTION 2 — THE NUMBERS
       ============================================ -->
  <section class="stats">
    <Container>
      <div class="stats__grid">
        <div class="stats__card">
          <p class="stats__number">$34B+</p>
          <p class="stats__label">Annual SaaS licensing waste across US enterprises</p>
        </div>
        <div class="stats__card">
          <p class="stats__number">975</p>
          <p class="stats__label">Average unknown cloud services per mid-market organization</p>
        </div>
        <div class="stats__card">
          <p class="stats__number">80%</p>
          <p class="stats__label">Employees using unapproved AI tools without IT oversight</p>
        </div>
      </div>
      <p class="stats__source">
        Sources: Gartner, Productiv, IBM Security Report 2026
      </p>
    </Container>
  </section>

  <!-- ============================================
       SECTION 3 — THE CORE PROBLEM
       ============================================ -->
  <section class="problem">
    <Container>
      <h2 class="section-title gold-bar">The Hidden Cost of What You Don't Know</h2>
      <div class="problem__grid">
        <div class="problem__card">
          <div class="problem__icon">
            <Icon name="ic:baseline-money-off" width="40px" height="40px" />
          </div>
          <h3>Financial Bleeding</h3>
          <p>
            Unused licenses. Duplicate tools. Forgotten subscriptions auto-renewing 
            on corporate cards nobody audits. The average 300-person company wastes 
            <strong>$180,000 annually</strong> on software nobody uses.
          </p>
        </div>
        <div class="problem__card">
          <div class="problem__icon">
            <Icon name="ic:baseline-security" width="40px" height="40px" />
          </div>
          <h3>Security Exposure</h3>
          <p>
            Every unapproved SaaS tool is an unlogged gateway into your network. 
            <strong>31% of former employees</strong> still have active access to 
            your systems right now.
          </p>
        </div>
        <div class="problem__card">
          <div class="problem__icon">
            <Icon name="ic:baseline-psychology" width="40px" height="40px" />
          </div>
          <h3>Shadow AI & IP Leakage</h3>
          <p>
            Your staff is pasting proprietary source code, unreleased financials, 
            and client data into consumer AI tools every day. Most enterprise 
            security stacks <strong>cannot see it happening.</strong>
          </p>
        </div>
      </div>
    </Container>
  </section>

  <!-- ============================================
       SECTION 4 — THE ATLAS DIFFERENCE
       ============================================ -->
  <section class="difference">
    <Container>
      <div class="difference__inner">
        <h2 class="difference__headline">We audit everything. We store nothing.</h2>
        <p class="difference__body">
          Every competitor in this space requires you to hand over your data. ATLAS operates 
          through a 100% Trustless Architecture — our platform runs inside your own 
          infrastructure, analyzes your data locally, delivers the findings, and 
          self-destructs. It is physically and mathematically impossible for your 
          organization to suffer a data breach through ATLAS.
        </p>
        <div class="difference__pillars">
          <div class="difference__pillar">
            <Icon name="ic:baseline-block" width="36px" height="36px" />
            <p><strong>Zero data stored</strong><br/>We never hold your files</p>
          </div>
          <div class="difference__pillar">
            <Icon name="ic:baseline-auto-delete" width="36px" height="36px" />
            <p><strong>Self-destructing containers</strong><br/>Audit complete, environment destroyed</p>
          </div>
          <div class="difference__pillar">
            <Icon name="ic:baseline-vpn-key" width="36px" height="36px" />
            <p><strong>Your AI keys, your terms</strong><br/>BYOM routing through your own enterprise MSA</p>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- ============================================
       SECTION 5 — HOW IT WORKS
       ============================================ -->
  <section class="how-it-works" id="how-it-works">
    <Container>
      <h2 class="section-title gold-bar">How It Works</h2>
      <p class="section-subtitle">Three steps. Under five minutes. Zero risk.</p>
      <div class="steps__grid">
        <div class="steps__card">
          <div class="steps__number">01</div>
          <h3>Connect</h3>
          <p>
            You authenticate read-only API access to your financial systems 
            and identity provider. Nothing is uploaded. Nothing leaves 
            your environment.
          </p>
        </div>
        <div class="steps__card">
          <div class="steps__number">02</div>
          <h3>Scan</h3>
          <p>
            ATLAS autonomously maps your entire digital infrastructure — 
            every tool, every license, every user, every AI endpoint — 
            in under 15 minutes.
          </p>
        </div>
        <div class="steps__card">
          <div class="steps__number">03</div>
          <h3>Recover</h3>
          <p>
            You receive a comprehensive 40-page executive report with exact 
            dollar figures, risk severity ratings, and a prioritized 
            remediation roadmap. Ready to present to your board.
          </p>
        </div>
      </div>
    </Container>
  </section>

  <!-- ============================================
       SECTION 6 — THE GUARANTEE
       ============================================ -->
  <section class="guarantee">
    <Container>
      <div class="guarantee__inner">
        <h2 class="guarantee__headline">Our Guarantee</h2>
        <p class="guarantee__body">
          If ATLAS does not uncover at least <strong>3× our fee</strong> in recoverable waste, 
          you pay nothing. Zero. We keep 20% of what we find. You keep the other 80%. 
          If we find nothing, we worked for free.
        </p>
        <a href="/company/contact" class="btn-navy">
          Claim Your Free Risk Assessment
        </a>
      </div>
    </Container>
  </section>

  <!-- ============================================
       SECTION 7 — WHO WE SERVE
       ============================================ -->
  <section class="industries">
    <Container>
      <h2 class="section-title gold-bar">Who We Serve</h2>
      <div class="industries__grid">
        <div class="industries__card">
          <div class="industries__icon">
            <Icon name="ic:baseline-local-hospital" width="40px" height="40px" />
          </div>
          <h3>Healthcare & BioTech</h3>
          <p>
            HIPAA compliance, PHI exposure detection, and clinical 
            Shadow AI auditing for organizations where data breaches 
            carry legal and human consequences.
          </p>
        </div>
        <div class="industries__card">
          <div class="industries__icon">
            <Icon name="ic:baseline-account-balance" width="40px" height="40px" />
          </div>
          <h3>FinTech & Regional Banking</h3>
          <p>
            SOC2, SOX, and PCI-DSS compliance readiness. We surface 
            every unauthorized tool touching your financial data 
            before regulators do.
          </p>
        </div>
        <div class="industries__card">
          <div class="industries__icon">
            <Icon name="ic:baseline-rocket-launch" width="40px" height="40px" />
          </div>
          <h3>High-Growth Tech & Professional Services</h3>
          <p>
            IP protection, developer shadow pipelines, and proprietary 
            code exposure. Protect your most valuable asset — 
            what you've built.
          </p>
        </div>
      </div>
    </Container>
  </section>

</Layout>

<style>

  /* ============================================
     HERO
     ============================================ */
  .hero {
    background-color: var(--color-primary, #0A1628);
    color: #ffffff;
    padding: 6rem 1.5rem;
  }
  .hero__inner {
    max-width: 780px;
    margin: 0 auto;
    text-align: center;
  }
  .hero__eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.75rem;
    color: var(--color-accent, #C9A84C);
    margin-bottom: 1.5rem;
    font-weight: 600;
  }
  .hero__headline {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    color: #ffffff;
    line-height: 1.15;
    margin-bottom: 1.5rem;
  }
  .hero__sub {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: rgba(255,255,255,0.82);
    max-width: 660px;
    margin: 0 auto 2.5rem auto;
    line-height: 1.7;
  }
  .hero__btns {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  /* ============================================
     BUTTONS
     ============================================ */
  .btn-gold {
    background-color: var(--color-accent, #C9A84C);
    color: var(--color-primary, #0A1628);
    padding: 0.85rem 1.75rem;
    border-radius: 6px;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    transition: background-color 150ms ease;
    display: inline-block;
  }
  .btn-gold:hover {
    background-color: #b08f3a;
    color: var(--color-primary, #0A1628);
  }
  .btn-outline-white {
    background-color: transparent;
    color: #ffffff;
    padding: 0.85rem 1.75rem;
    border-radius: 6px;
    border: 2px solid #ffffff;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    transition: all 150ms ease;
    display: inline-block;
  }
  .btn-outline-white:hover {
    background-color: #ffffff;
    color: var(--color-primary, #0A1628);
  }
  .btn-navy {
    background-color: var(--color-primary, #0A1628);
    color: #ffffff;
    padding: 0.85rem 1.75rem;
    border-radius: 6px;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    transition: background-color 150ms ease;
    display: inline-block;
    margin-top: 1.5rem;
  }
  .btn-navy:hover {
    background-color: #1a2d4a;
    color: #ffffff;
  }

  /* ============================================
     STATS
     ============================================ */
  .stats {
    background-color: #F8F9FA;
    padding: 4rem 1.5rem;
  }
  .stats__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    text-align: center;
  }
  .stats__card {
    padding: 2rem 1rem;
  }
  .stats__number {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    color: var(--color-accent, #C9A84C);
    margin: 0 0 0.5rem 0;
    line-height: 1;
  }
  .stats__label {
    color: var(--color-primary, #0A1628);
    font-size: 0.95rem;
    margin: 0;
    opacity: 0.85;
  }
  .stats__source {
    text-align: center;
    font-size: 0.75rem;
    opacity: 0.5;
    margin-top: 2rem;
  }

  /* ============================================
     PROBLEM
     ============================================ */
  .problem {
    padding: 5rem 1.5rem;
    background-color: #ffffff;
  }
  .problem__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 3rem;
  }
  .problem__card {
    padding: 2rem;
    border: 1px solid #E0E0E0;
    border-radius: 8px;
    transition: box-shadow 150ms ease;
  }
  .problem__card:hover {
    box-shadow: 0 4px 20px rgba(10, 22, 40, 0.08);
  }
  .problem__icon {
    color: var(--color-accent, #C9A84C);
    margin-bottom: 1rem;
  }
  .problem__card h3 {
    color: var(--color-primary, #0A1628);
    margin-bottom: 0.75rem;
  }
  .problem__card p {
    font-size: 0.95rem;
    opacity: 0.85;
    line-height: 1.7;
  }

  /* ============================================
     DIFFERENCE
     ============================================ */
  .difference {
    background-color: var(--color-primary, #0A1628);
    padding: 5rem 1.5rem;
    color: #ffffff;
  }
  .difference__inner {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }
  .difference__headline {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    color: var(--color-accent, #C9A84C);
    margin-bottom: 1.5rem;
  }
  .difference__body {
    color: rgba(255,255,255,0.85);
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: 3rem;
  }
  .difference__pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .difference__pillar {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    color: rgba(255,255,255,0.9);
  }
  .difference__pillar svg {
    color: var(--color-accent, #C9A84C);
  }
  .difference__pillar p {
    font-size: 0.9rem;
    text-align: center;
    line-height: 1.6;
    margin: 0;
  }

  /* ============================================
     HOW IT WORKS
     ============================================ */
  .how-it-works {
    padding: 5rem 1.5rem;
    background-color: #F8F9FA;
  }
  .steps__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 3rem;
  }
  .steps__card {
    background-color: #ffffff;
    border-radius: 8px;
    padding: 2.5rem 2rem;
    border-top: 4px solid var(--color-accent, #C9A84C);
    box-shadow: 0 2px 12px rgba(10,22,40,0.06);
  }
  .steps__number {
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-accent, #C9A84C);
    opacity: 0.3;
    line-height: 1;
    margin-bottom: 1rem;
  }
  .steps__card h3 {
    color: var(--color-primary, #0A1628);
    margin-bottom: 0.75rem;
  }
  .steps__card p {
    font-size: 0.95rem;
    opacity: 0.85;
    line-height: 1.7;
  }

  /* ============================================
     GUARANTEE
     ============================================ */
  .guarantee {
    background-color: var(--color-accent, #C9A84C);
    padding: 5rem 1.5rem;
  }
  .guarantee__inner {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }
  .guarantee__headline {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    color: var(--color-primary, #0A1628);
    margin-bottom: 1.5rem;
  }
  .guarantee__body {
    font-size: 1.1rem;
    color: var(--color-primary, #0A1628);
    line-height: 1.8;
    opacity: 0.9;
  }

  /* ============================================
     INDUSTRIES
     ============================================ */
  .industries {
    padding: 5rem 1.5rem;
    background-color: #ffffff;
  }
  .industries__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 3rem;
  }
  .industries__card {
    padding: 2rem;
    border: 1px solid #E0E0E0;
    border-radius: 8px;
    transition: box-shadow 150ms ease, transform 150ms ease;
  }
  .industries__card:hover {
    box-shadow: 0 4px 20px rgba(10,22,40,0.08);
    transform: translateY(-3px);
  }
  .industries__icon {
    color: var(--color-accent, #C9A84C);
    margin-bottom: 1rem;
  }
  .industries__card h3 {
    color: var(--color-primary, #0A1628);
    margin-bottom: 0.75rem;
  }
  .industries__card p {
    font-size: 0.95rem;
    opacity: 0.85;
    line-height: 1.7;
  }

  /* ============================================
     SHARED UTILITIES
     ============================================ */
  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    color: var(--color-primary, #0A1628);
    margin-bottom: 0.5rem;
  }
  .section-subtitle {
    color: #6B7280;
    font-size: 1.05rem;
    margin-bottom: 1rem;
  }
  .gold-bar::after {
    content: '';
    display: block;
    width: 60px;
    height: 4px;
    background-color: var(--color-accent, #C9A84C);
    margin-top: 0.75rem;
    margin-bottom: 1rem;
  }

  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 768px) {
    .stats__grid,
    .problem__grid,
    .difference__pillars,
    .steps__grid,
    .industries__grid {
      grid-template-columns: 1fr;
    }
    .hero {
      padding: 4rem 1.5rem;
    }
  }
</style>