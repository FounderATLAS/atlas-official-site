---
import { Icon } from 'astro-icon/components'
const { navData, rightMenu } = Astro.props;
---

<script type="module">
  const bodyElement = document.querySelector('body');
  const menuButton = document.querySelector('#menuButton');
  const navHeader = document.querySelector('#atlasNavHeader');
  const menuButtonIconHam = document.querySelector('#menuButtonIconHam');
  const menuButtonIconClose = document.querySelector('#menuButtonIconClose');
  let scrollPosition = 0;
  let lastScroll = 0;

  // Sticky header shrink on scroll
  window.addEventListener('scroll', () => {
    const header = document.querySelector('#atlasNavHeader');
    if (window.scrollY > 50) {
      header.classList.add('header--scrolled');
    } else {
      header.classList.remove('header--scrolled');
    }
  });

  menuButton.addEventListener('click', toggleMenu);

  function toggleMenu() {
    menuButtonIconHam.toggleAttribute('hidden');
    menuButtonIconClose.toggleAttribute('hidden');
    
    if (navHeader.hasAttribute('mobile-menu-open', true)) {
      menuButton.title = "Open Main Menu";
      bodyElement.style.removeProperty('overflow');
      bodyElement.style.removeProperty('position');
      bodyElement.style.removeProperty('top');
      bodyElement.style.removeProperty('width');
      window.scrollTo(0, scrollPosition);
    } else {
      menuButton.title = "Close Main Menu";
      scrollPosition = window.pageYOffset;
      bodyElement.style.overflow = 'hidden';
      bodyElement.style.position = 'fixed';
      bodyElement.style.top = `-${scrollPosition}px`;
      bodyElement.style.width = '100%';
    }
    
    navHeader.toggleAttribute('mobile-menu-open');
  }
</script>

<header id="atlasNavHeader">
  <div class="header__inner">
    <!-- Logo -->
    <div class="header-logo-menu__container">
      <button id="menuButton" title="Open Main Menu">
        <span id="menuButtonIconHam">
          <Icon name="ic:baseline-menu" width="24px" height="24px" />
        </span>
        <span id="menuButtonIconClose" hidden>
          <Icon name="ic:baseline-close" width="24px" height="24px" />
        </span>
      </button>
      <a class="header-logo__link" href="/">
        <slot name="logo"></slot>
      </a>
    </div>

    <!-- Center Nav -->
    <div class="header-nav__container">
      <slot name="nav">
        {navData && <nav>
          <ul>
            {navData.map(navItem => (
              <li><a href={navItem.slug}>{navItem.title}</a></li>
            ))}
          </ul>
        </nav>}
      </slot>
    </div>

    <!-- Right CTA -->
    <div class="header-action-item__container">
      <slot name="action-item"></slot>
    </div>
  </div>
</header>

<style>
  header {
    width: 100%;
    position: fixed;
    top: 0;
    left: 0;
    z-index: 1000;
    background-color: rgba(10, 22, 40, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(201, 168, 76, 0.15);
    transition: all 300ms ease;
    padding: 1rem 0;
  }

  header.header--scrolled {
    padding: 0.6rem 0;
    background-color: rgba(10, 22, 40, 0.98);
  }

  .header__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .header-logo__link {
    width: fit-content;
    color: #ffffff;
    text-decoration: none;
  }

  .header-logo-menu__container {
    display: flex;
    align-items: center;
    z-index: 100;
  }

  .header-action-item__container {
    z-index: 100;
  }

  #menuButton {
    outline: none;
    border: none;
    background-color: transparent;
    margin-right: 0.5rem;
    display: none;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  #menuButton > span {
    color: #ffffff;
    vertical-align: middle;
    transition: color 150ms ease;
  }

  #menuButton:hover > span {
    color: #C9A84C;
  }

  nav {
    display: flex;
  }

  nav ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    gap: 0.25rem;
  }

  nav ul li a {
    text-decoration: none;
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    transition: color 150ms ease, background-color 150ms ease;
  }

  nav ul li a:hover {
    color: #C9A84C;
    background-color: rgba(201, 168, 76, 0.08);
  }

  /* Mobile */
  @media (max-width: 768px) {
    #menuButton {
      display: block;
      z-index: 100;
    }

    .header-nav__container {
      width: 100%;
      height: 100%;
      background-color: rgba(10, 22, 40, 0.98);
      backdrop-filter: blur(16px);
      display: none;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      position: fixed;
      inset: 0;
      z-index: 99;
    }

    header[mobile-menu-open] .header-nav__container {
      display: flex;
    }

    header[mobile-menu-open] nav ul {
      align-items: center;
      flex-direction: column;
      gap: 0.5rem;
    }

    header[mobile-menu-open] nav ul li a {
      font-size: 1.25rem;
      padding: 0.75rem 1.5rem;
      color: #ffffff;
    }

    header[mobile-menu-open] nav ul li a:hover {
      color: #C9A84C;
    }
  }
</style>